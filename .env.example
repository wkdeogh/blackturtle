# Password gate (required)
SITE_PASSWORD=replace-with-a-long-unique-password
# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-with-at-least-32-random-characters

# Supabase server-only connection (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=replace-with-your-supabase-secret-key

# Data sources
FRED_API_KEY=replace-with-your-fred-api-key # required
# Required for the market-index tab. The free Basic plan is sufficient.
TWELVE_DATA_API_KEY=replace-with-your-twelve-data-api-key
# Optional: free Massive Futures Basic key for WTI front-month futures data
MASSIVE_API_KEY=replace-with-your-massive-api-key
X_BEARER_TOKEN=replace-with-your-x-bearer-token # required for X collection

# LLM sentiment analysis (required for X refresh)
OPENAI_API_KEY=replace-with-your-openai-api-key
# Optional override. The default is the low-cost classification model below.
OPENAI_MODEL=gpt-5.4-nano
# Optional override for cross-post recurring-theme summaries.
OPENAI_TOPIC_MODEL=gpt-5.4-nano
# Optional legacy fallback until the dashboard account settings migration is applied.
# Comma-separated usernames, without @. Up to 10 accounts in the MVP.
X_TARGET_USERNAMES=unusual_whales,elerianm
# Optional legacy fallback. Dashboard setting takes priority after migration 003.
X_LOOKBACK_DAYS=7
# Optional legacy fallbacks. Blank means unlimited.
X_PER_ACCOUNT_POST_LIMIT=
X_TOTAL_POST_LIMIT=
